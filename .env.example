MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=bitegit
JWT_SECRET=replace_with_long_random_secret
PORT=3000
NODE_ENV=production

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@admin.local
ADMIN_ROLE=SUPER_ADMIN

# Deployment domain/email (used in docs + SSL commands)
DOMAIN=bitegit.com
LETSENCRYPT_EMAIL=admin@bitegit.com

# Optional controls
ADMIN_SESSION_TTL_MINUTES=120
ADMIN_IP_WHITELIST=
ADMIN_FORCE_PASSWORD_SYNC=false
ADMIN_FORCE_ROLE_SYNC=false
ADMIN_FORCE_ACTIVATE=false

# Keep local Mongo disabled by default (Atlas-first)
ALLOW_LOCAL_MONGO=false

# OTP + Auth email flow
ALLOW_DEMO_OTP=false
SIGNUP_OTP_TTL_MS=600000

# Option A: Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND=
MAIL_FROM=
APP_NAME=BITEGIT

# Option B: SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# Option C: Gmail App Password
GMAIL_USER=
GMAIL_APP_PASSWORD=
